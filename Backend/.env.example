SECRET_KEY=your-50-char-django-secret-key
DEBUG=True
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Celery — password must be URL-encoded (@ → %40, # → %23, etc.)
CELERY_BROKER_URL=sqla+postgresql://postgres:[URL-ENCODED-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Brevo transactional email
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=your-verified-sender@example.com
BREVO_SENDER_NAME=Task Manager
